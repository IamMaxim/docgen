			"files": [".prettierrc", ".prettierignore"]
		},
		"eslint": {
			"files": ["eslint.config.js"],
			"devDependencies": {
				"eslint": "^9.39.1",
				"eslint-config-prettier": "^10.1.8",
				"eslint-plugin-svelte": "^3.13.0",
				"globals": "^16.5.0",
				"typescript-eslint": "^8.47.0"
			},
			"scripts": {
