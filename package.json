{
  "name": "docgen-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for @iammaxim/docgen and @iammaxim/create-docgen.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "cookie": "^0.7.2"
  },
  "scripts": {
    "build": "npm run build -w @iammaxim/docgen",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "check": "npm run check --workspaces --if-present"
  }
}
